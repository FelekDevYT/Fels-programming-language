using "fels.io.scanner"
using "fels.lang.sfm"

loop {
  print("> ") 
  command = scanner.readLine()

  if (command == "help") {
    println("Доступные команды: help, echo, exit") 
  } else if (command.startsWith("echo ")) { 
    println(command.substring(5,length(command)))
  } else if (command == "exit") {
    break 
  } else {
    println("Неизвестная команда: " + command) 
  }
}
